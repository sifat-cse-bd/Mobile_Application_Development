<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:id="@+id/main"
    android:layout_height="match_parent"
    android:background="#0F1123"
    android:padding="16dp">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:nestedScrollingEnabled="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/btnPrintReport">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="10dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="0dp"
            android:orientation="vertical">

            <!-- Header - Student Name Section -->
            <LinearLayout
                android:id="@+id/headerLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome back,"
                    android:textColor="#8E8E93"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvStdName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Faruk Ahmed Sifat"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Info Card - Student ID, Semester, Department -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/infoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#1D1F33"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvStdID"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ID: 23-51221-1"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:layout_marginBottom="10dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="10dp"
                        android:background="#2C2E4A" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Semester: Spring"
                            android:textColor="#B0B0B0"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dept: CSE"
                            android:textColor="#B0B0B0"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Grade Table -->
            <TableLayout
                android:id="@+id/tableLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="*"
                android:layout_marginBottom="15dp">

                <!-- Table Header Row -->
                <TableRow
                    android:background="#2C2E4A"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:text="Subject"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:padding="12dp" />

                    <TextView
                        android:text="Obtained"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:padding="12dp" />

                    <TextView
                        android:text="Total"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:padding="12dp" />

                    <TextView
                        android:text="Grade"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:padding="12dp" />
                </TableRow>
            </TableLayout>

            <!-- Summary Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="15dp">

                <TextView
                    android:id="@+id/tvSummary"
                    android:text="Total Subjects: 0 | Passed: 0 | Failed: 0"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:padding="10dp" />

                <!-- GPA Display -->
                <TextView
                    android:id="@+id/tvGPA"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GPA: 0.00"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#FF4B68"
                    android:padding="10dp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Input Section -->
            <LinearLayout
                android:id="@+id/inputSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add New Subject"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/edtSubName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/edittext_bg_dark"
                    android:hint="Subject Name"
                    android:paddingHorizontal="15dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#5A5A5A"
                    android:layout_marginBottom="12dp"
                    android:textSize="14sp"
                    android:inputType="text" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/edtObtainMark"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:background="@drawable/edittext_bg_dark"
                        android:hint="Obtained"
                        android:inputType="number"
                        android:paddingHorizontal="15dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#5A5A5A"
                        android:layout_marginEnd="8dp"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edtTotalMark"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="48dp"
                        android:background="@drawable/edittext_bg_dark"
                        android:hint="Total"
                        android:inputType="number"
                        android:paddingHorizontal="15dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#5A5A5A"
                        android:layout_marginEnd="8dp"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btnAddSubject"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:backgroundTint="#4CAF50"
                        android:text="Add"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:cornerRadius="8dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Print Report Button Fixed at Bottom -->
    <Button
        android:id="@+id/btnPrintReport"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="10dp"
        android:backgroundTint="#3F3F43"
        android:text="PRINT REPORT"
        android:textColor="#B4BECE"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:layout_editor_absoluteX="32dp" />

</androidx.constraintlayout.widget.ConstraintLayout>